---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
import { SITE } from "@/config";
import "@/styles/global.css";
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import {
  makeIds,
  buildWebSite,
  buildWebPage,
  buildArticle,
  assembleGraph,
} from "@jdevalk/seo-graph-core";

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
};

const {
  title = SITE.title.slice(0, 4) + " phải đi ngủ trước 9h30.",
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL,
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
} = Astro.props;

const canonicalUrlString = canonicalURL
  ? canonicalURL.toString()
  : new URL(Astro.url.pathname, Astro.url).toString();

const socialImageURL = new URL(ogImage, Astro.url).toString();

// Construct structured data Graph
const ids = makeIds({
  siteUrl: SITE.website,
  personUrl: SITE.profile,
});

const websitePiece = buildWebSite({
  url: SITE.website,
  name: SITE.title,
  publisher: { "@id": ids.person },
  inLanguage: SITE.lang ?? "en",
}, ids);

const webpagePiece = buildWebPage({
  url: canonicalUrlString,
  name: title,
  isPartOf: { "@id": ids.website },
  inLanguage: SITE.lang ?? "en",
  description: description,
}, ids);

const personPiece = {
  "@type": "Person",
  "@id": ids.person,
  name: author,
  url: profile,
  sameAs: [profile],
};

const graphPieces = [websitePiece, webpagePiece, personPiece];

if (pubDatetime) {
  const articlePiece = buildArticle({
    url: canonicalUrlString,
    isPartOf: { "@id": ids.webPage(canonicalUrlString) },
    author: { "@id": ids.person },
    publisher: { "@id": ids.person },
    headline: title,
    description: description,
    datePublished: pubDatetime,
    dateModified: modDatetime ?? undefined,
    inLanguage: SITE.lang ?? "en",
  }, ids, "BlogPosting");
  graphPieces.push(articlePiece);
}

const graph = assembleGraph(graphPieces as any);
---

<!doctype html>
<html
  dir={SITE.dir}
  lang=`${SITE.lang ?? "en"}`
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <Seo
      title={title}
      description={description}
      canonical={canonicalUrlString}
      ogType={pubDatetime ? "article" : "website"}
      ogImage={socialImageURL}
      siteName={SITE.title}
      author={author}
      extraLinks={[
        { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
        { rel: "sitemap", href: "/sitemap-index.xml" },
        {
          rel: "alternate",
          type: "application/rss+xml",
          title: SITE.title,
          href: new URL("rss.xml", Astro.site).toString(),
        },
      ]}
      extraMeta={[
        {
          name: "viewport",
          content: "width=device-width, initial-scale=1, viewport-fit=cover",
        },
        { name: "generator", content: Astro.generator },
        ...(PUBLIC_GOOGLE_SITE_VERIFICATION
          ? [{ name: "google-site-verification", content: PUBLIC_GOOGLE_SITE_VERIFICATION }]
          : []),
      ]}
      graph={graph}
    />

    <!-- Load Font -->
    <Font
      cssVariable="--font-roboto-mono"
      preload={[{ subset: "latin", weight: 400, style: "normal" }]}
    />

    <meta name="theme-color" content="" />

    <ClientRouter />

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        const initialColorScheme = ""; // "light" | "dark"
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
  </head>
  <body>
    <slot />

    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>
  </body>
</html>
