---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h2 class="my-4 inline-block text-4xl font-bold sm:my-8">@9h30.zzz</h2>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        Ở đây có một chút công nghệ, một chút chuyện đời và thật nhiều sự suy
        ngẫm. Blog cá nhân của Tùng ghi lại những trải nghiệm thực tế trong công
        việc và cuộc sống, trước khi ánh đèn phòng kịp tắt lúc 9 giờ rưỡi tối.
      </p>

      <p
        class="mt-2 text-sm text-accent italic"
        id="sleep-notice"
        style="display: none"
      >
        Bây giờ là: <span id="currentTime"></span>. Tùng đã đi ngủ rồi, bạn cũng
        nên thế nhé!
      </p>
      <script is:inline>
        (function () {
          function pad(num) {
            return num.toString().padStart(2, "0");
          }
          const now = new Date();
          let hour = now.getHours();
          const minute = now.getMinutes();
          const ampm = hour >= 12 ? "PM" : "AM";
          hour = hour % 12;
          if (hour === 0) hour = 12;
          const timeStr = `${pad(hour)}:${pad(minute)}${ampm}`;
          // Set current time in the span
          var timeSpan = document.getElementById("currentTime");
          if (timeSpan) {
            timeSpan.textContent = timeStr;
          }
          // Display the sleep notice if after 21:30 (9:30 PM) or before 6:00 AM
          const isLate = (hour > 9 || (hour === 9 && minute >= 30));
          const isEarly = (hour < 6);
          if (isLate || isEarly) {
            document.getElementById("sleep-notice").style.display = "";
          }
     
        })();
      </script>
      {
        // only display if at least one social link is enabled
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Nổi bật</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Bài viết gần đây</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        Tất cả bài viết
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
